{
  "name": "prism-code-review",
  "version": "0.1.2",
  "description": "AI-powered code review assistant — generates hunk-level summaries for GitHub PRs",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "prism": "dist/cli.js"
  },
  "files": [
    "dist/",
    "prompts/"
  ],
  "scripts": {
    "build": "tsc",
    "build:bundle": "node esbuild.config.js",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "smoke-test": "tsx src/smoke-test.ts",
    "build:bin": "bun build src/cli.ts --compile --outfile ../prism",
    "prepublishOnly": "cd ../shared && rm -f tsconfig.tsbuildinfo && npx tsc -p tsconfig.json && cd ../daemon && npm run clean && npm run build:bundle && cp ../README.md ."
  },
  "keywords": [
    "code-review",
    "github",
    "pull-request",
    "ai",
    "llm",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/you06/PRism.git",
    "directory": "daemon"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@prism/shared": "workspace:*",
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
